{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tool-contract.schema.json",
  "type": "object",
  "required": ["version", "tools"],
  "properties": {
    "version": { "type": "string" },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/tool" }
    }
  },
  "$defs": {
    "tool": {
      "type": "object",
      "required": [
        "name",
        "type",
        "dataSensitivity",
        "riskTier",
        "idempotent",
        "timeoutMs",
        "rateLimitPerMin",
        "schema",
        "errors"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*\\.[a-z][a-z0-9]*\\.v[0-9]+$"
        },
        "type": { "type": "string", "enum": ["READ_ONLY", "TRANSACTIONAL"] },
        "dataSensitivity": { "type": "string", "enum": ["NONE", "PII", "PHI"] },
        "riskTier": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH"] },
        "idempotent": { "type": "boolean" },
        "requiresApprovalId": { "type": "boolean" },
        "timeoutMs": { "type": "integer", "minimum": 1000 },
        "rateLimitPerMin": { "type": "integer", "minimum": 1 },
        "schema": {
          "type": "object",
          "required": ["input", "output"],
          "properties": {
            "input": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": { "type": "string" }
            },
            "output": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": { "type": "string" }
            }
          },
          "additionalProperties": false
        },
        "errors": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true,
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "TRANSACTIONAL" } },
            "required": ["type"]
          },
          "then": {
            "properties": { "requiresApprovalId": { "const": true } },
            "required": ["requiresApprovalId"]
          }
        }
      ]
    }
  },
  "additionalProperties": false
}